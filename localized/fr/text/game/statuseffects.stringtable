    <Entry>
      <ID>7</ID>
      <DefaultText>&lt;line-height=100%&gt;Toucher avec un sort accorde {0:value:percent} de chances de &lt;link="glossary://GlossaryEntry_Charmed"&gt;&lt;#00a4ff&gt;charme&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_intellect" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt;r la cible&lt;/line-height&gt;</DefaultText>
      <FemaleText />
