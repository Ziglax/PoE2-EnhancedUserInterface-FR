      <FemaleText />
    </Entry>
    <Entry>
      <ID>123</ID>
      <DefaultText>La capacité est conférée quand le porteur est &lt;link="glossary://GlossaryEntry_Near_Death"&gt;&lt;#ff462d&gt;Proche de la mort&lt;/color&gt;&lt;/link&gt;</DefaultText>
