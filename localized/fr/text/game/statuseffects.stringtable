      <FemaleText />
    </Entry>
    <Entry>
      <ID>216</ID>
      <DefaultText>&lt;line-height=100%&gt;Cône de &lt;link="glossary://GlossaryEntry_Disoriented"&gt;&lt;#ca58ff&gt;Désorientation&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_perception" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; orienté vers une cible touchée par un coup critique&lt;/line-height&gt;</DefaultText>
