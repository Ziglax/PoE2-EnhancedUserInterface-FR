      <ID>729</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Dexterity"&gt;&lt;#dac79c&gt;Inspiration de Dextérité&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Swift"&gt;&lt;#72da26&gt;Vélocité&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_dexterity" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Dextérité, +100 % d'Allure et ne peuvent pas être engagés par l'ennemi.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>731</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Perception"&gt;&lt;#dac79c&gt;Inspiration de Perception&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Insightful"&gt;&lt;#ca58ff&gt;Subtilité&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_perception" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=75%&gt;&lt;font="EBGaramond-Regular SDF"&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Perception.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>733</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Perception"&gt;&lt;#dac79c&gt;Inspiration de Perception&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Aware"&gt;&lt;#ca58ff&gt;Conscience&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_perception" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Perception et 50 % des éraflures sont converties en coups normaux.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>735</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Perception"&gt;&lt;#dac79c&gt;Inspiration de Perception&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Intuitive"&gt;&lt;#ca58ff&gt;Intuition&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_perception" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Perception, 50 % des éraflures sont converties en coups normaux et 25 % des coups normaux sont convertis en critiques.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>737</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Intellect"&gt;&lt;#dac79c&gt;Inspiration d'Intelligence&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Smart"&gt;&lt;#00a4ff&gt;Sagacité&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_intellect" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=75%&gt;&lt;font="EBGaramond-Regular SDF"&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Intelligence.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>739</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Intellect"&gt;&lt;#dac79c&gt;Inspiration d'Intelligence&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Acute"&gt;&lt;#00a4ff&gt;Astuce&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_intellect" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Intelligence et leurs capacités et sorts gagnent 1 Niveau de pouvoir supplémentaire.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>741</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Intellect"&gt;&lt;#dac79c&gt;Inspiration d'Intelligence&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Brilliant"&gt;&lt;#00a4ff&gt;Perspicacité&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_intellect" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt;, gagnent +5 en Intelligence, leurs capacités et sorts gagnent 1 Niveau de pouvoir supplémentaire et regagnent périodiquement des ressources liées à leur classe.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>743</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Resolve"&gt;&lt;#dac79c&gt;Inspiration de Détermination&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Steadfast"&gt;&lt;#30d3d5&gt;Fermeté&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_resolve" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=75%&gt;&lt;font="EBGaramond-Regular SDF"&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; gagnent +5 en Détermination.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>745</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Resolve"&gt;&lt;#dac79c&gt;Inspiration de Détermination&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Resolute"&gt;&lt;#30d3d5&gt;Opiniâtreté&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_resolve" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; bénéficient de +5 en Détermination et gagnent périodiquement de la Concentration.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>747</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Inspirations_Resolve"&gt;&lt;#dac79c&gt;Inspiration de Détermination&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
Les personnages sous &lt;link="glossary://GlossaryEntry_Courageous"&gt;&lt;#30d3d5&gt;Courage&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_resolve" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; bénéficient de +5 en Détermination et sont immunisés aux interruptions.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>753</ID>
      <DefaultText>&lt;line-height=100%&gt;Les personnages qui sont résistants à un type d'affliction diminueront d'un cran les effets subis des afflictions de ce type qui leur sont appliqués. Par exemple, sur un personnage résistant aux &lt;link="glossary://GlossaryEntry_Afflictions_Might"&gt;&lt;#ff4800&gt;afflictions touchant la Puissance&lt;/color&gt;&lt;/link&gt;, l'affliction &lt;link="glossary://GlossaryEntry_Stunned"&gt;&lt;#ff4800&gt;Assommement&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; serait rétrogradée en &lt;link="glossary://GlossaryEntry_Dazed"&gt;&lt;#ff4800&gt;Étourdissement&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt;. &lt;link="glossary://GlossaryEntry_Dazed"&gt;&lt;#ff4800&gt;Étourdissement&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; serait rétrogradée en &lt;link="glossary://GlossaryEntry_Staggered"&gt;&lt;#ff4800&gt;Stupéfaction&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=75%&gt;&lt;font="EBGaramond-Regular SDF"&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt;, et &lt;link="glossary://GlossaryEntry_Staggered"&gt;&lt;#ff4800&gt;Stupéfaction&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=75%&gt;&lt;font="EBGaramond-Regular SDF"&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; ne serait pas appliquée. Les personnage étant résistants aux attaques physiques ou magiques obtiennent une chance de les esquiver, sans subir les moindres effets négatifs.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>755</ID>
      <DefaultText>&lt;line-height=100%&gt;Les personnages qui sont vulnérables à un type d'affliction verront les effets subis augmenter d'un cran. Par exemple, sur un personnage vulnérable aux &lt;link="glossary://GlossaryEntry_Afflictions_Might"&gt;&lt;#ff4800&gt;afflictions de Puissance&lt;/color&gt;&lt;/link&gt;, &lt;link="glossary://GlossaryEntry_Staggered"&gt;&lt;#ff4800&gt;Stupéfaction&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=75%&gt;&lt;font="EBGaramond-Regular SDF"&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; serait augmentée en &lt;link="glossary://GlossaryEntry_Dazed"&gt;&lt;#ff4800&gt;Étourdissement&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt;, ou &lt;link="glossary://GlossaryEntry_Dazed"&gt;&lt;#ff4800&gt;Étourdissement&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; en &lt;link="glossary://GlossaryEntry_Stunned"&gt;&lt;#ff4800&gt;Assommement&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_might" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt;.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>758</ID>
      <DefaultText>&lt;line-height=100%&gt;Les afflictions qui influent sur les attributs d'Intelligence, de Perception et de Détermination font partie des &lt;link="gamedata://9a2f5d84-96ef-453b-b52c-f698b2a0e8da"&gt;&lt;#b574d3&gt;afflictions mentales&lt;/color&gt;&lt;/link&gt;.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>760</ID>
      <DefaultText>&lt;line-height=100%&gt;Les afflictions qui influent sur les attributs de Puissance, de Constitution et de Dextérité sont appelées &lt;link="glossary://GlossaryEntry_Body_Affliction"&gt;&lt;#d39674&gt;afflictions corporelles&lt;/color&gt;&lt;/link&gt;.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>769</ID>
      <DefaultText>&lt;line-height=100%&gt;Les rôdeurs partagent littéralement un lien vital avec leur compagnon animal. Lorsque l'un est blessé, l'autre le ressent sous forme d'une intense souffrance émotionnelle. Si un rôdeur ou un compagnon animal tombe inconscient, son partenaire souffre de Chagrin lié, ce qui diminue sa &lt;link="glossary://GlossaryEntry_Accuracy"&gt;Précision&lt;space=0.7em&gt;&lt;sprite="Inline" name="cs_accuracy" tint=1&gt;&lt;/link&gt; et d'autres statistiques jusqu'à ce que l'allié terrassé soit ranimé. Si jamais un rôdeur est tué, son compagnon animal meurt instantanément de chagrin.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>883</ID>
      <DefaultText>Un personnage dont la &lt;link="gamedata://91e98392-f468-44a4-83bd-1e9d1cc2e1aa"&gt;&lt;#80e27e&gt;santé&lt;/color&gt;&lt;space=0.3em&gt;&lt;voffset=0.1em&gt;&lt;size=80%&gt;&lt;#80e27e&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;space=-0.8em&gt;&lt;voffset=0.8em&gt;&lt;size=45%&gt;&lt;#4caf50&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/link&gt; est comprise entre 50 % et 25 % est considéré « &lt;link="glossary://GlossaryEntry_Bloodied"&gt;&lt;#FF9800&gt;Ensanglanté&lt;space=0.75em&gt;&lt;size=1.25em&gt;&lt;voffset=-0.35em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;#FF9800CC&gt;&lt;voffset=-0.125em&gt;-&lt;/voffset&gt;&lt;/color&gt;&lt;space=-1.55em&gt;&lt;#83838397&gt;&lt;voffset=0.125em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=0.35em&gt;-&lt;/voffset&gt;&lt;/color&gt;&lt;/size&gt;&lt;/color&gt;&lt;/link&gt; ».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>885</ID>
      <DefaultText>Un personnage dont la &lt;link="gamedata://91e98392-f468-44a4-83bd-1e9d1cc2e1aa"&gt;&lt;#80e27e&gt;santé&lt;/color&gt;&lt;space=0.3em&gt;&lt;voffset=0.1em&gt;&lt;size=80%&gt;&lt;#80e27e&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;space=-0.8em&gt;&lt;voffset=0.8em&gt;&lt;size=45%&gt;&lt;#4caf50&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/link&gt; est comprise entre 75 % et 50 % est considéré « &lt;link="glossary://GlossaryEntry_Hurt"&gt;&lt;#FDD835&gt;Blessé&lt;/color&gt;&lt;space=0.75em&gt;&lt;size=1.15em&gt;&lt;#FDD835FF&gt;&lt;voffset=-0.35em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=-0.125em&gt;-&lt;/voffset&gt;&lt;/color&gt;&lt;space=-1.55em&gt;&lt;#FDD835&gt;&lt;voffset=0.125em&gt;-&lt;/voffset&gt;&lt;/color&gt;&lt;space=-1.55em&gt;&lt;#83838397&gt;&lt;voffset=0.35em&gt;-&lt;/voffset&gt;&lt;/color&gt;&lt;/size&gt;&lt;/link&gt; ».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>887</ID>
      <DefaultText>Un personnage dont la &lt;link="gamedata://91e98392-f468-44a4-83bd-1e9d1cc2e1aa"&gt;&lt;#80e27e&gt;santé&lt;/color&gt;&lt;space=0.3em&gt;&lt;voffset=0.1em&gt;&lt;size=80%&gt;&lt;#80e27e&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;space=-0.8em&gt;&lt;voffset=0.8em&gt;&lt;size=45%&gt;&lt;#4caf50&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/link&gt; est inférieure à 100 % et supérieure à 75 % est considéré comme « &lt;link="glossary://GlossaryEntry_Healthy"&gt;&lt;#b5d925&gt;Égratigné&lt;space=0.75em&gt;&lt;size=1.25em&gt;&lt;voffset=-0.35em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=-0.125em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=0.125em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=0.35em&gt;-&lt;/voffset&gt;&lt;/color&gt;&lt;/size&gt;&lt;/link&gt; ».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>889</ID>
      <DefaultText>Un personnage dont la &lt;link="gamedata://91e98392-f468-44a4-83bd-1e9d1cc2e1aa"&gt;&lt;#80e27e&gt;santé&lt;/color&gt;&lt;space=0.3em&gt;&lt;voffset=0.1em&gt;&lt;size=80%&gt;&lt;#80e27e&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;space=-0.8em&gt;&lt;voffset=0.8em&gt;&lt;size=45%&gt;&lt;#4caf50&gt;&lt;sprite="Inline" name="cs_health" tint=1&gt;&lt;/color&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/link&gt; est égale à 100 % est considéré « &lt;link="glossary://GlossaryEntry_Unharmed"&gt;&lt;#43e629&gt;Indemne&lt;space=0.75em&gt;&lt;size=1.25em&gt;&lt;voffset=-0.35em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=-0.125em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=0.1em&gt;-&lt;/voffset&gt;&lt;space=-1.55em&gt;&lt;voffset=0.60em&gt;&lt;size=1em&gt;+&lt;/size&gt;&lt;/voffset&gt;&lt;space=-1.54em&gt;&lt;voffset=0.59em&gt;&lt;size=1em&gt;+&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/size&gt;&lt;/link&gt; ».</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>1103</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Afflictions_Perception"&gt;&lt;#dac79c&gt;Afflictions touchant la Perception&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
 &lt;link="glossary://GlossaryEntry_Blinded"&gt;&lt;#ca58ff&gt;Les personnages aveuglés&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_perception" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;3&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; souffrent de -5 en Perception, sont considérés comme contournés, +50 % d'Initiative, -10 en &lt;link="glossary://GlossaryEntry_Accuracy"&gt;Précision&lt;space=0.7em&gt;&lt;sprite="Inline" name="cs_accuracy" tint=1&gt;&lt;/link&gt;, et la portée de toutes leurs attaques à distance est divisée par deux. Les personnages aveuglés ne peuvent ni utiliser ni subir d'attaques de Regard.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>1104</ID>
      <DefaultText>&lt;line-height=100%&gt;&lt;voffset=0.5em&gt;&lt;size=95%&gt;&lt;link="glossary://GlossaryEntry_Afflictions_Perception"&gt;&lt;#dac79c&gt;Afflictions touchant la Perception&lt;/color&gt;&lt;/link&gt;&lt;/size&gt;&lt;/voffset&gt;
 &lt;link="glossary://GlossaryEntry_Disoriented"&gt;&lt;#ca58ff&gt;Les personnages désorientés&lt;space=0.7em&gt;&lt;sprite="Inline" name="attribute_perception" tint=1&gt;&lt;space=0.3em&gt;&lt;voffset=-0.35em&gt;&lt;size=80%&gt;&lt;b&gt;2&lt;/b&gt;&lt;/size&gt;&lt;/voffset&gt;&lt;/color&gt;&lt;/link&gt; subissent -5 en Perception, sont considérés comme contournés, et subissent +50 % d'Initiative après leurs actions.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>388372001</ID>
      <DefaultText>&lt;line-height=100%&gt;La Roue&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
    <Entry>
      <ID>388372002</ID>
      <DefaultText>&lt;line-height=100%&gt;Considérée comme de conception engwithienne, la Roue — également connue sous les noms de « &lt;link="glossary://GlossaryEntry_Beraths_Wheel"&gt;Roue de Berath&lt;/link&gt; » ou « Roue de la Vie et de la &lt;xg&gt;Mort&lt;/xg&gt; » — permet le processus de réincarnation. À la mort d'une créature vivante, son âme entre dans l'Entre-deux. Lorsque l'Entre-deux est saturé, les âmes passent dans l'Au-delà, où elles attendent d'être redistribuées dans de nouveaux corps, de nouvelles vies.

Sans la Roue, et donc sans le moyen de passer dans l'Au-delà, on suppose que les âmes de tous les défunts &lt;i&gt;resteraient&lt;/i&gt; dans l'Entre-deux. L'Au-delà se viderait, mettant à terme fin à la vie telle que nous la connaissons sur Eora.

On ignore toutefois quand la Roue a été construite, et ce qui — s'il y avait quelque chose — l'a précédée.&lt;/line-height&gt;</DefaultText>
      <FemaleText />
    </Entry>
  </Entries>
</StringTableFile>